@model IEnumerable<PortalAcademico.Models.Curso>
@{ ViewData["Title"] = "Panel de Coordinador"; }

<h2>Gestión de Cursos</h2>
<p><a asp-action="Create" class="btn btn-primary">Crear Nuevo Curso</a></p>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.Codigo</td>
            <td>@item.Nombre</td>
            <td>
                <span class="badge @(item.Activo ? "bg-success" : "bg-danger")">
                    @(item.Activo ? "Activo" : "Inactivo")
                </span>
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                <a asp-action="Matriculas" asp-route-cursoId="@item.Id" class="btn btn-sm btn-info">Ver Matrículas</a>
                <form asp-action="ToggleEstado" asp-route-id="@item.Id" method="post" style="display:inline;">
                    <button type="submit" class="btn btn-sm @(item.Activo ? "btn-danger" : "btn-success")">
                        @(item.Activo ? "Desactivar" : "Activar")
                    </button>
                </form>
            </td>
        </tr>
}
    </tbody>
</table>