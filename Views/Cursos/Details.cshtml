@model PortalAcademico.Models.Curso

@{
    ViewData["Title"] = "Detalles del Curso";
}

<div class="container mt-4">
    <h2>@Model.Nombre</h2>
    <hr />
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Código</dt>
                <dd class="col-sm-9">@Model.Codigo</dd>

                <dt class="col-sm-3">Créditos</dt>
                <dd class="col-sm-9">@Model.Creditos</dd>

                <dt class="col-sm-3">Cupos Máximos</dt>
                <dd class="col-sm-9">@Model.CupoMaximo</dd>

                <dt class="col-sm-3">Horario</dt>
                <dd class="col-sm-9">@Model.HorarioInicio.ToString(@"hh\:mm") - @Model.HorarioFin.ToString(@"hh\:mm")</dd>
            </dl>
        </div>
    </div>

    <div>
        <a asp-controller="Matriculas" asp-action="Inscripcion" asp-route-cursoId="@Model.Id" class="btn btn-success btn-lg">Inscribirse</a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-lg ms-2">Volver al catálogo</a>
    </div>
</div>